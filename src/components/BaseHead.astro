---
import '../styles/global.css';
import '../styles/theme.css';
import { SITE_CONTACT_EMAIL, SITE_DOMAIN, SITE_KEYWORDS, SITE_THEME_COLOR, SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: string;
	keywords?: string[];
	pageType?: "website" | "article";
	robots?: string;
	publishedTime?: string;
	modifiedTime?: string;
	section?: string;
	tags?: string[];
	schemas?: Record<string, unknown>[];
	breadcrumbs?: { name: string; path: string }[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
	title,
	description,
	image = '/og-cover.svg',
	keywords = SITE_KEYWORDS,
	pageType = "website",
	robots = "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1",
	publishedTime,
	modifiedTime,
	section,
	tags = [],
	schemas = [],
	breadcrumbs = [],
} = Astro.props;

const imageURL = new URL(image, Astro.site ?? Astro.url);
const organizationId = new URL('#organization', Astro.site ?? Astro.url);
const websiteId = new URL('#website', Astro.site ?? Astro.url);
const schemaGraph = [
	{
		'@type': 'Organization',
		'@id': organizationId,
		name: SITE_TITLE,
		alternateName: SITE_DOMAIN,
		url: Astro.site,
		email: SITE_CONTACT_EMAIL,
	},
	{
		'@type': 'WebSite',
		'@id': websiteId,
		name: SITE_TITLE,
		alternateName: SITE_DOMAIN,
		url: Astro.site,
		description,
		publisher: {
			'@id': organizationId,
		},
	},
	{
		'@type': 'WebPage',
		name: title,
		url: canonicalURL,
		description,
		isPartOf: {
			'@id': websiteId,
		},
	},
	...(breadcrumbs.length > 0
		? [
				{
					'@type': 'BreadcrumbList',
					itemListElement: breadcrumbs.map((item, index) => ({
						'@type': 'ListItem',
						position: index + 1,
						name: item.name,
						item: new URL(item.path, Astro.site),
					})),
				},
			]
		: []),
	...schemas,
];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content={SITE_THEME_COLOR} />
<meta name="robots" content={robots} />
<meta name="author" content={SITE_TITLE} />
<meta name="keywords" content={keywords.join(", ")} />
<meta name="referrer" content="strict-origin-when-cross-origin" />
<meta name="format-detection" content="telephone=no" />

<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />
<link rel="alternate" type="application/rss+xml" title={`${SITE_TITLE} RSS feed`} href="/rss.xml" />
<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content={pageType === "article" ? "article" : "website"} />
<meta property="og:locale" content="en_US" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
{section && <meta property="article:section" content={section} />}
{tags.map((tag) => <meta property="article:tag" content={tag} />)}

<script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', '@graph': schemaGraph })} />
