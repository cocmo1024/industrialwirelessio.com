---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`About | ${SITE.title}`}>
  <Header />
  <Main pageTitle="About" pageDesc={`About ${SITE.title}`}>
    <div class="app-prose max-w-app">
      <p>
        Industrial Wireless I/O is an independent English-language publication focused on wireless I/O, industrial telemetry, and field connectivity architecture.
      </p>
      <p>
        The site favors concise, durable publishing that helps readers understand network tradeoffs, remote monitoring patterns, and practical field connectivity decisions.
      </p>
    </div>
  </Main>
  <Footer />
</Layout>
