---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`Disclaimer | ${SITE.title}`}>
  <Header />
  <Main
    pageTitle="Disclaimer"
    pageDesc={`${SITE.title} publishes informational content. This page sets expectations for how that content should be interpreted.`}
  >
    <div class="app-prose max-w-app">
      <p>
        Content on this site is provided for general informational purposes only.
      </p>
      <p>
        Readers should verify important details with primary sources and qualified professionals before making decisions.
      </p>
      <p>
        Questions can be sent to <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>.
      </p>
    </div>
  </Main>
  <Footer />
</Layout>
