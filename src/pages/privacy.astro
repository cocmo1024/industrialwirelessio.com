---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`Privacy Policy | ${SITE.title}`}>
  <Header />
  <Main
    pageTitle="Privacy Policy"
    pageDesc={`This policy explains how ${SITE.title} may collect and use limited information when you visit this website.`}
  >
    <div class="app-prose max-w-app">
      <p>
        This site may collect limited analytics, technical logs, and information you provide voluntarily through email.
      </p>
      <p>
        Information may be used to operate the site, understand usage, and respond to inquiries.
      </p>
      <p>
        Questions can be sent to <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>.
      </p>
    </div>
  </Main>
  <Footer />
</Layout>
