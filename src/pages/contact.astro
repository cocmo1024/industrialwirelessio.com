---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`Contact | ${SITE.title}`}>
  <Header />
  <Main
    pageTitle="Contact"
    pageDesc={`Use email to contact ${SITE.title} about editorial corrections, business inquiries, or general questions.`}
  >
    <div class="app-prose max-w-app">
      <p>
        Email: <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>
      </p>
      <p>
        Email is the primary contact channel for this website.
      </p>
    </div>
  </Main>
  <Footer />
</Layout>
