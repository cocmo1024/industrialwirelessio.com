---
import SidebarCard from '../components/SidebarCard.astro';
import ClassicShell from '../layouts/ClassicShell.astro';
import { SITE_CONTACT_EMAIL, SITE_KEYWORDS, SITE_TITLE } from '../consts';
import {
	SITE_AVOID_TOPICS,
	SITE_CONTENT_FORMATS,
	SITE_EDITOR,
	SITE_METHOD_PRINCIPLES,
	SITE_REVIEW_PROMISE,
	SITE_UPDATE_PLAYBOOK,
} from '../sitePlan';
---

<ClassicShell
	title={`${SITE_TITLE} | Methodology`}
	description={`Editorial methodology for ${SITE_TITLE}.`}
	pageTitle="Methodology for building a durable, trustworthy field connectivity archive"
	pageIntro="This page explains how Industrial Wireless I/O should choose topics, shape comparisons, and keep architecture-heavy pages useful long enough to become trusted field references."
	introLabel="Methodology"
	keywords={[...SITE_KEYWORDS, 'editorial methodology', 'field connectivity evaluation framework', 'content standards']}
	breadcrumbs={[
		{ name: 'Home', path: '/' },
		{ name: 'Methodology', path: '/methodology/' },
	]}
>
	<Fragment slot="left-rail">
		<SidebarCard title="Editorial Desk" eyebrow="Who Publishes">
			<p><strong>{SITE_EDITOR.name}</strong></p>
			<p>{SITE_EDITOR.role}</p>
			<p>{SITE_EDITOR.bio}</p>
		</SidebarCard>

		<SidebarCard title="Review Promise" eyebrow="Maintenance">
			<p>{SITE_REVIEW_PROMISE}</p>
		</SidebarCard>
	</Fragment>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Working Rules</p>
				<h2>How field connectivity topics should be covered</h2>
			</div>
		</div>
		<div class="detail-grid">
			{SITE_METHOD_PRINCIPLES.map((principle) => (
				<article class="detail-card">
					<p class="section-kicker">Principle</p>
					<h3>{principle.title}</h3>
					<p>{principle.summary}</p>
				</article>
			))}
		</div>
	</section>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Preferred Formats</p>
				<h2>What good pages look like on this site</h2>
			</div>
		</div>
		<div class="detail-grid">
			{SITE_CONTENT_FORMATS.map((format) => (
				<article class="detail-card">
					<p class="section-kicker">Format</p>
					<h3>{format.title}</h3>
					<p>{format.summary}</p>
				</article>
			))}
		</div>
	</section>

	<div class="policy-grid">
		<section class="policy-card">
			<p class="section-kicker">Avoid</p>
			<h3>Low-value patterns to resist</h3>
			<ul>
				{SITE_AVOID_TOPICS.map((item) => (
					<li>{item}</li>
				))}
			</ul>
		</section>

		<section class="policy-card">
			<p class="section-kicker">Update Cadence</p>
			<h3>How the archive should stay fresh</h3>
			<ul>
				{SITE_UPDATE_PLAYBOOK.map((step) => (
					<li><strong>{step.title}:</strong> {step.summary}</li>
				))}
			</ul>
		</section>
	</div>

	<section class="section-block">
		<div class="section-head">
			<div>
				<p class="eyebrow">Contact</p>
				<h2>Editorial corrections and topic suggestions</h2>
			</div>
		</div>
		<p>
			If you see a field-architecture or reliability detail that needs correction, email
			<a href={`mailto:${SITE_CONTACT_EMAIL}`}> {SITE_CONTACT_EMAIL}</a>. The best field manuals stay
			useful because important pages are reviewed instead of abandoned.
		</p>
	</section>
</ClassicShell>
