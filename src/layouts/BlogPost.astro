---
import type { CollectionEntry } from 'astro:content';
import AdSlot from '../components/AdSlot.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SidebarCard from '../components/SidebarCard.astro';
import ClassicShell from './ClassicShell.astro';
import { NAV_BLOG_LABEL, SITE_KEYWORDS, SITE_TITLE } from '../consts';
import { SITE_EDITOR } from '../sitePlan';
import { categoryPath, estimateReadingMinutes, tagPath } from '../utils/content';

interface Props {
	post: CollectionEntry<'blog'>;
	headings: { depth: number; slug: string; text: string }[];
	relatedPosts: CollectionEntry<'blog'>[];
	slug: string;
}

const { post, headings = [], relatedPosts = [], slug } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, category, tags, primaryAudience, buyerStage, valueFocus, reviewCycle } = post.data;
const readingMinutes = estimateReadingMinutes(post.body);
const breadcrumbItems = [
	{ name: 'Home', path: '/' },
	{ name: NAV_BLOG_LABEL, path: '/blog/' },
	{ name: category, path: categoryPath(category) },
	{ name: title, path: `/blog/${slug}/` },
];

const articleSchema = {
	'@type': 'BlogPosting',
	headline: title,
	description,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	mainEntityOfPage: new URL(`/blog/${slug}/`, Astro.site),
	author: {
		'@type': 'Organization',
		name: SITE_EDITOR.name,
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
	},
	articleSection: category,
	keywords: [category, ...tags],
	image: heroImage ? [new URL(heroImage, Astro.site)] : undefined,
};
---

<ClassicShell
	title={title}
	description={description}
	image={heroImage}
	showPageIntro={false}
	pageType="article"
	keywords={[...SITE_KEYWORDS, category, ...tags]}
	publishedTime={pubDate.toISOString()}
	modifiedTime={(updatedDate ?? pubDate).toISOString()}
	section={category}
	tags={tags}
	schemas={[articleSchema]}
	breadcrumbs={breadcrumbItems}
>
	<Fragment slot="left-rail">
		<SidebarCard title="Entry Details" eyebrow="Article">
			<p><strong>Published:</strong> <FormattedDate date={pubDate} /></p>
			<p><strong>Reading time:</strong> {readingMinutes} min</p>
			<p><strong>Category:</strong> <a href={categoryPath(category)}>{category}</a></p>
			{primaryAudience && <p><strong>Best for:</strong> {primaryAudience}</p>}
			{buyerStage && <p><strong>Stage:</strong> {buyerStage}</p>}
			{
				updatedDate && (
					<p><strong>Updated:</strong> <FormattedDate date={updatedDate} /></p>
				)
			}
			{reviewCycle && <p><strong>Review cycle:</strong> {reviewCycle}</p>}
		</SidebarCard>
		{
			headings.length > 0 && (
				<SidebarCard title="On This Page" eyebrow="Navigation">
					<ul>
						{headings.filter((heading) => heading.depth <= 3).map((heading) => (
							<li><a href={`#${heading.slug}`}>{heading.text}</a></li>
						))}
					</ul>
				</SidebarCard>
			)
		}
	</Fragment>

	<Fragment slot="right-rail">
		<SidebarCard title="Related Reads" eyebrow="Internal Links">
			<ul>
				{relatedPosts.map((relatedPost) => (
					<li><a href={`/blog/${relatedPost.id}/`}>{relatedPost.data.title}</a></li>
				))}
			</ul>
		</SidebarCard>
	</Fragment>

	<article class="article-shell">
		<Breadcrumbs items={breadcrumbItems} />

		<header class="article-header">
			<p class="eyebrow">Latest Entry</p>
			<h1>{title}</h1>
			<p class="article-description">{description}</p>
			<div class="meta-row">
				<FormattedDate date={pubDate} />
				<span>{readingMinutes} min read</span>
				<a href={categoryPath(category)}>{category}</a>
				{
					updatedDate && (
						<>
							<span aria-hidden="true">/</span>
							<span>Updated <FormattedDate date={updatedDate} /></span>
						</>
					)
				}
			</div>
			<div class="tag-row">
				{tags.map((tag) => (
					<a class="taxonomy-tag" href={tagPath(tag)}>{tag}</a>
				))}
			</div>
		</header>

		{
			heroImage && (
				<div class="article-hero">
					<img src={heroImage} alt="" width={1280} height={720} />
				</div>
			)
		}

		<AdSlot
			slotId="article-inline-break"
			format="inline"
			headline="In-article sponsor break"
			note="This responsive in-content unit creates a natural monetization pause near the top of the article without pushing the whole layout around."
		/>

		<div class="article-prose prose">
			<slot />
		</div>

		<section class="section-block">
			<div class="section-head">
				<div>
					<p class="eyebrow">Next Reads</p>
					<h3>Keep exploring this topic cluster</h3>
				</div>
			</div>
			<ul class="link-list">
				{relatedPosts.map((relatedPost) => (
					<li><a href={`/blog/${relatedPost.id}/`}>{relatedPost.data.title}</a></li>
				))}
				<li><a href={categoryPath(category)}>Browse every {category} article</a></li>
			</ul>
		</section>

		<section class="section-block">
			<div class="section-head">
				<div>
					<p class="eyebrow">Editorial Context</p>
					<h3>Why this page belongs in the archive</h3>
				</div>
			</div>
			<div class="detail-grid">
				<article class="detail-card">
					<p class="section-kicker">Audience</p>
					<h3>{primaryAudience ?? 'Readers evaluating this workflow topic'}</h3>
					<p>
						This article is designed to help readers who need durable information rather than trend
						commentary, which is why it sits inside a larger topic cluster.
					</p>
				</article>
				<article class="detail-card">
					<p class="section-kicker">Buyer Stage</p>
					<h3>{buyerStage ?? 'Evergreen research'}</h3>
					<p>
						{valueFocus ?? 'The goal is to move readers closer to a clearer evaluation or implementation decision.'}
					</p>
				</article>
				<article class="detail-card">
					<p class="section-kicker">Method</p>
					<h3>{SITE_EDITOR.name}</h3>
					<p>
						Read the <a href="/methodology">methodology</a> page to see how this site chooses topics,
						updates high-value pages, and avoids thin content.
					</p>
				</article>
			</div>
		</section>

		<AdSlot
			slotId="article-footer-banner"
			format="banner"
			headline="End-of-article billboard"
			note="A closing wide placement works well for partner promos, newsletter CTAs, or a direct-sold banner."
		/>

		<AdSlot
			slotId="article-mobile-unit"
			format="mobile"
			headline="Mobile after-article slot"
			note="Reserve a dedicated mobile unit after the article body so smaller screens still have a clean, predictable placement."
		/>
	</article>
</ClassicShell>
